{
  "name": "strict-csp-next",
  "version": "0.1.0",
  "description": "Strict CSP for Next.js App Router. No unsafe-inline. Pages stay static.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "license": "MIT",
  "author": "North Shore Software Labs",
  "homepage": "https://github.com/NorthShoreSoftwareLabs/strict-csp-next",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NorthShoreSoftwareLabs/strict-csp-next.git"
  },
  "keywords": [
    "next",
    "nextjs",
    "csp",
    "content-security-policy",
    "strict-csp",
    "nonce",
    "hash",
    "security",
    "app-router",
    "ppr",
    "cache-components"
  ],
  "bin": {
    "strict-csp-next": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./proxy": {
      "types": "./dist/proxy.d.ts",
      "import": "./dist/proxy.js",
      "require": "./dist/proxy.cjs"
    },
    "./cache-handler": {
      "types": "./dist/cache-handler.d.ts",
      "import": "./dist/cache-handler.js",
      "require": "./dist/cache-handler.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "lint:fix": "biome check --write",
    "test": "pnpm build && node --test test/*.test.mjs",
    "prepare": "pnpm build"
  },
  "peerDependencies": {
    "next": ">=16"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.10.0",
    "next": "^16.2.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
